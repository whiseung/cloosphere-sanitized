# Presenton 배포 설정 — 이 파일을 .env 로 복사해서 채울 것.
#   cp .env.example .env
#
# Cloosphere 와 완전 별개로 동작하는 독립 서비스 설정이다.

# ── 포트 / 이미지 ────────────────────────────────────────────────────────────
PRESENTON_PORT=5001
PRESENTON_TAG=latest

# ── 핵심: 인증 비활성화 (MCP 무인증 + 생성물 공개 다운로드) ─────────────────────
# 내부망 전용 배포 전제. 공개 인터넷에 직접 노출하지 말 것.
DISABLE_AUTH=true

# 내부 렌더링 URL — export 시 "컨테이너 내부" 브라우저가 여는 주소.
# 반드시 컨테이너 내부에서 도달 가능해야 함 = nginx :80 = http://localhost.
# ⚠️ 호스트 published 포트(http://localhost:5001)를 넣으면 export 가 500 으로 실패한다.
#    사용자 다운로드 링크는 generate 가 주는 상대경로에 http://<호스트>:5001 을 붙여 만든다.
NEXT_PUBLIC_URL=http://localhost

# ── LLM 공급자 (택1) ─────────────────────────────────────────────────────────
# LLM 값을 아래 중 하나로 두고 해당 블록만 채우면 된다.
LLM=openai

# (A) OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# (B) Azure OpenAI  → LLM=azure 로 변경 후 사용
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<리소스>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=<배포이름>
# AZURE_OPENAI_MODEL=gpt-4o

# (C) Anthropic  → LLM=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-7-sonnet-latest

# (D) OpenAI 호환 게이트웨이  → LLM=custom
# CUSTOM_LLM_URL=https://<게이트웨이>/v1
# CUSTOM_LLM_API_KEY=
# CUSTOM_MODEL=<모델명>
#
# (D-1) 토큰 사용량 추적: Cloosphere 게이트웨이로 라우팅
#   Presenton 텍스트 LLM을 Cloosphere의 OpenAI 호환 엔드포인트로 보내면, 그 토큰이
#   Cloosphere usage(message_type=external_service)에 기록된다. (이미지 토큰은 별도, 미집계)
#   ⚠️ 전용 "서비스 계정" API 키 사용 권장(사람 사용자에게 귀속되지 않게). 컨테이너→호스트는
#      host.docker.internal. CUSTOM_MODEL은 Cloosphere가 서빙하는 모델 id.
# LLM=custom
# CUSTOM_LLM_URL=http://host.docker.internal:8080/openai/v1
# CUSTOM_LLM_API_KEY=sk-<cloosphere 서비스계정 키>
# CUSTOM_MODEL=gpt-4o

# ── 이미지 생성 ──────────────────────────────────────────────────────────────
# 처음엔 끄고(true) 텍스트 슬라이드부터 검증 권장. 켜려면 false + 아래 설정.
DISABLE_IMAGE_GENERATION=true
# IMAGE_PROVIDER: pexels | pixabay | dall-e-3 | gemini_flash | comfyui | open_webui
# IMAGE_PROVIDER=pexels
# PEXELS_API_KEY=
# PIXABAY_API_KEY=
# DALL_E_3_QUALITY=standard

# ── 운영 ─────────────────────────────────────────────────────────────────────
CAN_CHANGE_KEYS=false
DISABLE_ANONYMOUS_TRACKING=true
# PostgreSQL 쓸 때만 (미설정 시 SQLite). 예) postgresql://user:pass@host:5432/presenton
# DATABASE_URL=
