# Microsoft 365 MCP 배포 설정 — 이 파일을 .env 로 복사해서 채울 것.
#   cp .env.example .env
#
# Cloosphere 와 완전 별개로 동작하는 독립 서비스 설정이다. 자세한 내용: ./README.md

# ── 포트 / 버전 ──────────────────────────────────────────────────────────────
# 호스트 노출 포트. Cloosphere 마켓플레이스 Microsoft 365 기본 URL 이 :8001/mcp 이므로 8001 권장.
M365_MCP_PORT=8001
# npm @softeria/ms-365-mcp-server 버전. 업그레이드 시 이 값 변경 후 `make build && make restart`.
MS365_MCP_VERSION=0.114.0

# ── org/work 계정 모드 ───────────────────────────────────────────────────────
# true: Teams/Chats/SharePoint Sites/공유메일함/온라인미팅 도구 노출(서버 플래그 --org-mode 와 동일).
# ⚠️ Teams chat/channel·온라인미팅 도구는 Cloosphere 의 GRAPH_DELEGATED_SCOPES 에
#    ChannelMessage.Read.All / Chat.Read / OnlineMeetings.Read 등을 추가하고 재로그인해야 실동작.
#    기본 스코프는 Mail / Calendar / Files(OneDrive) / SharePoint(read) / Contacts / Tasks / Notes 까지 커버.
M365_MCP_ORG_MODE=true

# ── (선택) 인바운드 토큰 검증 일관성 ─────────────────────────────────────────
# 비워두면 softeria 내장 멀티테넌트 앱('common') 사용. Cloosphere 로그인과 동일 클라이언트/테넌트로
# 맞추려면 Cloosphere 의 MICROSOFT_CLIENT_ID / MICROSOFT_CLIENT_TENANT_ID 값을 그대로 넣는다.
# passthrough 모드에선 필수 아님(인바운드 Bearer 를 그대로 Graph 로 전달).
MS365_MCP_CLIENT_ID=
MS365_MCP_TENANT_ID=

# ── (선택) 운용 ──────────────────────────────────────────────────────────────
# 쓰기 도구 차단(읽기 전용)으로 운용하려면 true.
M365_MCP_READ_ONLY=false
M365_MCP_LOG_LEVEL=info

# ⚠️ 절대 설정 금지 (각각 멀티유저 격리/토큰 audience 를 깸):
#   MS365_MCP_OAUTH_TOKEN   — startup 시 읽는 정적 단일 토큰 = 모든 사용자 공유(단일유저화)
#   MS365_MCP_CLIENT_SECRET — passthrough 에 불필요(설정 시 confidential/OBO 경로로 빠질 수 있음)
# 서버 플래그 --obo / --trust-proxy-auth 도 쓰지 말 것
#   --obo            : On-Behalf-Of (confidential client + api://<clientId>/access_as_user 토큰 필요,
#                      Cloosphere 가 가진 graph-audience 토큰과 불일치)
#   --trust-proxy-auth: Bearer 검사를 건너뛰고 로컬 MSAL 단일계정 캐시로 fallback (멀티유저 깨짐)
