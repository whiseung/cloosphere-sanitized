# Google Workspace MCP 배포 설정 — 이 파일을 .env 로 복사해서 채울 것.
#   cp .env.example .env
#
# Cloosphere 와 완전 별개로 동작하는 독립 서비스 설정이다. 자세한 내용: ./README.md

# ── 포트 / 버전 ──────────────────────────────────────────────────────────────
GWS_MCP_PORT=8000
# PyPI workspace-mcp 버전. 업그레이드 시 이 값 변경 후 `make build && make restart`.
WORKSPACE_MCP_VERSION=1.21.0

# ── 토큰 검증용 Google OAuth 클라이언트 (필수) ───────────────────────────────
# ⚠️ Cloosphere 로그인에 쓰는 것과 "동일한" 클라이언트를 사용할 것.
#    (Cloosphere 설정 경로: oauth.google.client_id, 환경변수 GOOGLE_CLIENT_ID)
#    이 서버는 OAuth 플로우를 돌리지 않고, 인바운드 access_token 을 Google userinfo 로
#    검증하는 용도로만 client id 를 쓴다.
GOOGLE_OAUTH_CLIENT_ID=

# confidential 클라이언트(시크릿 있음)면 채움 — Cloosphere 와 동일한 값.
# public PKCE 클라이언트(시크릿 없음)면 비워두고 아래 JWT 서명 키를 설정.
GOOGLE_OAUTH_CLIENT_SECRET=

# public 클라이언트 모드에서만 필요. 생성: openssl rand -hex 32
# FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY=

# ── 리버스 프록시 뒤일 때만 ──────────────────────────────────────────────────
# WORKSPACE_EXTERNAL_URL=https://gws-mcp.example.com
