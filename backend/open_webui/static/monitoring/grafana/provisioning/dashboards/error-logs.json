              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 200 }
            ]
          }
        }
      },
      "title": "Warnings (selected period)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=~\"$service\"} | detected_level =~ \"WARN\" [$__range]))",
          "refId": "A"
        }
      ]
