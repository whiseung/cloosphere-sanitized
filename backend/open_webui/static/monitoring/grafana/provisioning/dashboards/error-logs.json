  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cloosphere", "logs"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "hide": 0,
        "description": "App service name",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": {"type": "label_values", "label": "service_name"},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "label": "Service",
        "sort": 1,
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "regex": "/^(?!loki|grafana|prometheus|otel-collector|promtail|postgres-exporter|redis-exporter).*$/"
      },
      {
        "current": { "selected": true, "text": ["ERROR", "WARN", "CRITICAL"], "value": ["ERROR", "WARN", "CRITICAL"] },
        "description": "Log level filter",
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "name": "level",
        "options": [
          { "selected": true, "text": "ERROR", "value": "ERROR" },
          { "selected": true, "text": "WARN", "value": "WARN" },
          { "selected": true, "text": "CRITICAL", "value": "CRITICAL" },
          { "selected": false, "text": "INFO", "value": "INFO" }
        ],
        "query": "ERROR,WARN,CRITICAL,INFO",
        "type": "custom",
        "label": "Level"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "Search keyword in log messages",
        "hide": 0,
        "name": "search",
        "query": "",
        "type": "textbox",
        "label": "Search"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
