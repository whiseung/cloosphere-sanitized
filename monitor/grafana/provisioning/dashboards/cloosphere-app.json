{
  "uid": "cloosphere-app",
  "title": "Cloosphere App",
  "tags": ["cloosphere"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(http_server_duration_milliseconds_count, http_method)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      },
      {
        "name": "status",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(http_server_duration_milliseconds_count, http_status_code)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_method=~\"$method\",http_status_code=~\"$status\"}[5m])) by (http_target)",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_method=~\"$method\",http_status_code=~\"4..\"}[5m])) by (http_target)",
          "legendFormat": "4xx {{http_target}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_method=~\"$method\",http_status_code=~\"5..\"}[5m])) by (http_target)",
          "legendFormat": "5xx {{http_target}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_sum{http_method=~\"$method\",http_status_code=~\"$status\"}[5m])) by (http_target) / sum(rate(http_server_duration_milliseconds_count{http_method=~\"$method\",http_status_code=~\"$status\"}[5m])) by (http_target)",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{http_method=~\"$method\",http_status_code=~\"$status\"}[5m])) by (http_target, le))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Requests by Status Code",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "stacking": {"mode": "normal"}},
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_method=~\"$method\"}[5m])) by (http_status_code)",
          "legendFormat": "{{http_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(http_server_active_requests{http_method=~\"$method\"}) by (http_method)",
          "legendFormat": "{{http_method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top 10 Slowest Endpoints (Avg ms)",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "decimals": 1},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Endpoint"}, "properties": [{"id": "custom.width", "value": 350}]},
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"sortBy": [{"displayName": "Value", "desc": true}]},
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_server_duration_milliseconds_sum[5m])) by (http_target) / sum(rate(http_server_duration_milliseconds_count[5m])) by (http_target))",
          "legendFormat": "{{http_target}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {"id": "organize", "options": {"renameByName": {"http_target": "Endpoint", "Value": "Avg Latency"}}}
      ]
    },
    {
      "id": 8,
      "title": "Top 10 Busiest Endpoints (req/s)",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "decimals": 2},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Endpoint"}, "properties": [{"id": "custom.width", "value": 350}]},
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"sortBy": [{"displayName": "Value", "desc": true}]},
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_server_duration_milliseconds_count[5m])) by (http_target))",
          "legendFormat": "{{http_target}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {"id": "organize", "options": {"renameByName": {"http_target": "Endpoint", "Value": "Request Rate"}}}
      ]
    },
    {
      "id": 9,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "db_client_connections_usage{state=\"used\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "db_client_connections_usage{state=\"idle\"}",
          "legendFormat": "idle",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
